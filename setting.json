{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "mcp__ide__getDiagnostics",
      "mcp__ide__executeCode"
    ]
  },
  "model": "claude-fable-5[1m]",
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "agentPushNotifEnabled": true,
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/yichiche/agent-box/memory/bin/memory-sync.sh >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
