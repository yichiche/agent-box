#!/usr/bin/env bash
#
# pre-commit hook: enforces the git author/committer identity.
# - Blocks if user.name or user.email is not set.
# - Blocks unless the identity is EXACTLY the required one (no other option).
# - Also checks the RESOLVED author/committer ident (git var) so a
#   `git commit --author=...` or GIT_AUTHOR_*/GIT_COMMITTER_* override can't slip past.
#

REQUIRED_NAME="jacky.cheng"
REQUIRED_EMAIL="yichiche@amd.com"
REQUIRED="${REQUIRED_NAME} <${REQUIRED_EMAIL}>"

USER_NAME=$(git config user.name)
USER_EMAIL=$(git config user.email)

# Block if identity is missing
ERRORS=""
[ -z "$USER_NAME" ]  && ERRORS="${ERRORS}  - user.name is not set\n"
[ -z "$USER_EMAIL" ] && ERRORS="${ERRORS}  - user.email is not set\n"
if [ -n "$ERRORS" ]; then
  echo ""
  echo "ERROR: Git identity is not configured."
  echo ""
  echo -e "$ERRORS"
  echo "  This repo requires committing as:"
  echo "    git config user.name  \"${REQUIRED_NAME}\""
  echo "    git config user.email \"${REQUIRED_EMAIL}\""
  echo ""
  exit 1
fi

# Helpers: pull "Name <email>" out of a `git var *_IDENT` string ("Name <email> ts tz")
ident_of() { printf '%s' "$1" | sed -E 's/> .*/>/'; }

AUTHOR_IDENT=$(ident_of "$(git var GIT_AUTHOR_IDENT 2>/dev/null)")
COMMITTER_IDENT=$(ident_of "$(git var GIT_COMMITTER_IDENT 2>/dev/null)")

# Enforce: configured identity AND resolved author/committer must all equal REQUIRED.
BAD=""
[ "$USER_NAME" = "$REQUIRED_NAME" ]   || BAD="${BAD}  - config user.name is '$USER_NAME' (must be '$REQUIRED_NAME')\n"
[ "$USER_EMAIL" = "$REQUIRED_EMAIL" ] || BAD="${BAD}  - config user.email is '$USER_EMAIL' (must be '$REQUIRED_EMAIL')\n"
[ -z "$AUTHOR_IDENT" ]    || [ "$AUTHOR_IDENT" = "$REQUIRED" ]    || BAD="${BAD}  - author is '$AUTHOR_IDENT' (must be '$REQUIRED')\n"
[ -z "$COMMITTER_IDENT" ] || [ "$COMMITTER_IDENT" = "$REQUIRED" ] || BAD="${BAD}  - committer is '$COMMITTER_IDENT' (must be '$REQUIRED')\n"

if [ -n "$BAD" ]; then
  echo ""
  echo "ERROR: Commits in this repo must be authored by ${REQUIRED} only."
  echo ""
  echo -e "$BAD"
  echo "  Fix your identity with:"
  echo "    git config user.name  \"${REQUIRED_NAME}\""
  echo "    git config user.email \"${REQUIRED_EMAIL}\""
  echo ""
  echo "  (Do NOT use 'git commit --author=...' or GIT_AUTHOR_*/GIT_COMMITTER_* to override.)"
  echo ""
  exit 1
fi

echo "Committing as: ${USER_NAME} <${USER_EMAIL}>  ✓"
exit 0
